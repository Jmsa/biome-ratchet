  "dependencies": {
    "chalk": "4.1.2"
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "@types/node": "22.13.10",
    "typescript": "5.7.3",
    "vitest": "3.0.9"
  }
