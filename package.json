{
  "name": "biome-ratchet",
  "version": "0.1.0",
  "description": "Ratcheting applied to Biome lint results so new issues don't creep in.",
  "main": "dist/cli.js",
  "bin": {
    "biome-ratchet": "./dist/cli.js"
  },
  "files": [
    "dist",
